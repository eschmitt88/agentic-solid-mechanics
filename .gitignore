# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# DVC manages large artifacts; ignore the cache itself
/.dvc/cache
/.dvc/tmp

# Quarto
/.quarto/
*_files/

# OS / editor
.DS_Store
*.swp

# Large binary artifacts that should not be in Git
*.ckpt
*.pt
*.bin
*.safetensors
*.parquet
*.arrow
*.tar
*.tar.gz
*.zip

# CalculiX solver byproducts — regenerable, large. Keep code (.py) and
# the small JSON results (reference.json, agent_result.json), drop the rest.
experiments/**/*.inp
experiments/**/*.dat
experiments/**/*.frd
experiments/**/*.sta
experiments/**/*.cvg
experiments/**/*.12d
experiments/**/spooles.out
experiments/**/*.out
experiments/**/*.bak
# Per-trial agent scratch dirs from batch runs (regenerable; keep the summary
# JSON in results/ and the curated demo, not every trial's scratch decks).
experiments/**/results/agent_runs/
